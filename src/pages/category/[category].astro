---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const categories = [...new Set(posts.map((post) => post.data.category))];
  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((post) => post.data.category === category)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    }
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`${category} | Writing & Photos`} description={`浏览「${category}」分类下的文章。`}>
  <section class="page-intro">
    <a class="back-link" href="/category/">全部分类</a>
    <p class="eyebrow">Category</p>
    <h1>{category}</h1>
    <p>这个主题下共有 {posts.length} 篇记录。</p>
  </section>
  <section class="feature-grid">
    {
      posts.map((post) => (
        <a class="post-card glow-card" href={`/posts/${post.id}/`}>
          <img src={post.data.cover} alt="" loading="lazy" decoding="async" />
          <div class="post-card-body">
            <span>
              {post.data.date.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit"
              })}
            </span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
