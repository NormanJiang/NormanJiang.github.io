---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import heroStaticImage from "../../public/images/hero-static.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = posts.filter((post) => post.data.featured);
const categoryCards = [...new Set(posts.map((post) => post.data.category))]
  .sort()
  .map((category) => {
    const categoryPosts = posts.filter((post) => post.data.category === category);
    return {
      name: category,
      count: categoryPosts.length,
      cover: categoryPosts[0]?.data.cover,
      latestTitle: categoryPosts[0]?.data.title
    };
  });
---

<BaseLayout
  title="Norman's Blog | 个人图文写作"
  description="一个明亮、有序、带有杂志感的个人图文写作网站。"
>
  <section class="hero">
    <div class="hero-copy">
      <h1>把日常的亮色，整理成可以回看的图文。</h1>
      <p class="hero-text">
        这里会存放个人创作、照片、札记与缓慢形成的文章。先保持清晰，之后让内容慢慢长出更多路径。
      </p>
      <div class="hero-actions">
        <a class="button button-ghost" href="#latest">阅读最新</a>
        <a class="button button-ghost" href="#article-types">浏览分类</a>
        <a class="button button-ghost" href="/timeline/">时间线</a>
      </div>
    </div>
    <div class="hero-card hero-static-image glow-card">
      <Picture
        src={heroStaticImage}
        alt=""
        widths={[720, 960, 1200]}
        sizes="(max-width: 820px) 100vw, 48vw"
        formats={["webp", "jpg"]}
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="hero-welcome" aria-label="Welcome smile handwritten animation">
        <svg viewBox="0 0 560 160" role="img" aria-hidden="true">
          <text class="welcome-text" x="36" y="98">
            <tspan style="--char-delay: 0ms">W</tspan>
            <tspan style="--char-delay: 90ms">e</tspan>
            <tspan style="--char-delay: 180ms">l</tspan>
            <tspan style="--char-delay: 270ms">c</tspan>
            <tspan style="--char-delay: 360ms">o</tspan>
            <tspan style="--char-delay: 450ms">m</tspan>
            <tspan style="--char-delay: 540ms">e</tspan>
            <tspan style="--char-delay: 630ms"> </tspan>
            <tspan style="--char-delay: 720ms">:</tspan>
            <tspan style="--char-delay: 810ms">)</tspan>
          </text>
        </svg>
      </div>
    </div>
  </section>

  <section class="section-band">
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>精选文章</h2>
    </div>
    <div class="feature-grid">
      {
        featured.map((post) => (
          <a class="post-card glow-card" href={`/posts/${post.id}/`}>
            <img src={post.data.cover} alt="" loading="lazy" decoding="async" />
            <div class="post-card-body">
              <span>{post.data.category}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section-band" id="latest">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>最新记录</h2>
    </div>
    <div class="latest-list">
      {
        posts.map((post) => (
          <a class="latest-row" href={`/posts/${post.id}/`}>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit"
              })}
            </time>
            <strong>{post.data.title}</strong>
            <span>{post.data.category}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section-band" id="article-types">
    <div class="section-heading">
      <p class="eyebrow">Categories</p>
      <h2>文章类型</h2>
    </div>
    <div class="category-showcase">
    {
      categoryCards.map((category) => (
        <a class="category-showcase-card glow-card" href={`/category/${encodeURIComponent(category.name)}/`}>
          {category.cover && <img src={category.cover} alt="" loading="lazy" decoding="async" />}
          <div>
            <span>{category.count} 篇文章</span>
            <h3>{category.name}</h3>
            {category.latestTitle && <p>最新：{category.latestTitle}</p>}
          </div>
        </a>
      ))
    }
    </div>
  </section>
</BaseLayout>
