---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const articleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);
---

<BaseLayout title={`${post.data.title} | Norman's Blog`} description={post.data.description}>
  <aside class="reading-progress" aria-label="阅读进度" data-reading-progress>
    <div class="reading-progress-track">
      <span class="reading-progress-fill" data-reading-progress-fill></span>
    </div>
    <div class="reading-progress-panel">
      <span class="reading-progress-kicker">阅读进度</span>
      <strong data-reading-progress-percent>0%</strong>
      {
        articleHeadings.length > 0 && (
          <div class="reading-progress-section">
            <span>当前段落</span>
            <p data-reading-current-heading>{articleHeadings[0].text}</p>
            <ol>
              {articleHeadings.map((heading) => (
                <li class={`depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`} data-heading-id={heading.slug}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </div>
        )
      }
    </div>
  </aside>
  <article class="article">
    <a class="back-link" href="/">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
      <span>返回首页</span>
    </a>
    <header class="article-header">
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString("zh-CN", {
          year: "numeric",
          month: "long",
          day: "numeric"
        })}
      </time>
    </header>
    <img class="article-cover" src={post.data.cover} alt="" loading="eager" decoding="async" fetchpriority="high" />
    <div class="article-body" data-article-body>
      <Content />
    </div>
  </article>
  <script is:inline>
    (() => {
      const article = document.querySelector("[data-article-body]");
      const fill = document.querySelector("[data-reading-progress-fill]");
      const percent = document.querySelector("[data-reading-progress-percent]");
      const currentHeading = document.querySelector("[data-reading-current-heading]");
      const links = [...document.querySelectorAll("[data-heading-id]")];

      if (!article || !fill || !percent) return;

      const searchQuery = new URLSearchParams(window.location.search).get("q")?.trim();

      const clearSearchHighlights = () => {
        article.querySelectorAll("mark.article-search-hit").forEach((mark) => {
          mark.replaceWith(document.createTextNode(mark.textContent || ""));
        });
        article.normalize();
        history.replaceState({}, "", window.location.pathname);
      };

      const highlightSearchResults = () => {
        if (!searchQuery) return;

        const expression = new RegExp(searchQuery.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "gi");
        const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
          acceptNode(node) {
            const parent = node.parentElement;
            if (!node.nodeValue?.trim() || !parent || parent.closest("script, style, mark")) {
              return NodeFilter.FILTER_REJECT;
            }
            expression.lastIndex = 0;
            return expression.test(node.nodeValue) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
          }
        });
        const matches = [];
        let node;
        while ((node = walker.nextNode())) matches.push(node);

        let firstHit;
        matches.forEach((textNode) => {
          const fragment = document.createDocumentFragment();
          const value = textNode.nodeValue;
          let cursor = 0;
          expression.lastIndex = 0;
          let match;

          while ((match = expression.exec(value))) {
            if (match.index > cursor) fragment.append(value.slice(cursor, match.index));
            const mark = document.createElement("mark");
            mark.className = "article-search-hit";
            mark.textContent = match[0];
            fragment.append(mark);
            firstHit ||= mark;
            cursor = match.index + match[0].length;
          }
          if (cursor < value.length) fragment.append(value.slice(cursor));
          textNode.replaceWith(fragment);
        });

        if (firstHit) {
          firstHit.id = "search-result";
          requestAnimationFrame(() => firstHit.scrollIntoView({ behavior: "smooth", block: "center" }));
        }
      };

      highlightSearchResults();
      article.addEventListener("click", (event) => {
        if (event.target.closest("mark.article-search-hit")) clearSearchHighlights();
      });

      const headingPairs = links
        .map((link) => ({
          link,
          element: document.getElementById(link.dataset.headingId)
        }))
        .filter((pair) => pair.element);

      const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

      const update = () => {
        const rect = article.getBoundingClientRect();
        const start = window.scrollY + rect.top;
        const end = start + article.scrollHeight - window.innerHeight;
        const rawProgress = end <= start ? 1 : (window.scrollY - start) / (end - start);
        const progress = clamp(rawProgress, 0, 1);
        const rounded = Math.round(progress * 100);

        fill.style.transform = window.matchMedia("(max-width: 820px)").matches
          ? `scaleX(${progress})`
          : `scaleY(${progress})`;
        percent.textContent = `${rounded}%`;

        if (headingPairs.length === 0 || !currentHeading) return;

        let active = headingPairs[0];
        for (const pair of headingPairs) {
          if (pair.element.getBoundingClientRect().top <= 140) {
            active = pair;
          }
        }

        currentHeading.textContent = active.link.textContent.trim();
        for (const pair of headingPairs) {
          pair.link.classList.toggle("is-active", pair === active);
        }
      };

      update();
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
    })();
  </script>
</BaseLayout>
