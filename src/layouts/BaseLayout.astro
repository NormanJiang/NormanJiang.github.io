---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Writing & Photos",
  description = "个人图文写作与影像记录"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      window.addEventListener("DOMContentLoaded", () => {
        const items = document.querySelectorAll(
          ".site-header, .hero-copy > *, .hero-card, .section-heading, .post-card, .latest-row, .category-strip a, .page-intro > *, .category-card, .article-header > *, .article-cover, .article-body > *, .article-nav, .reading-progress"
        );

        document.documentElement.classList.add("is-prepping-enter");

        items.forEach((item, index) => {
          item.setAttribute("data-enter", "");
          item.style.setProperty("--enter-delay", `${Math.min(index * 34, 420)}ms`);
        });

        requestAnimationFrame(() => {
          document.documentElement.classList.remove("is-prepping-enter");
          document.documentElement.classList.add("is-ready-enter");
        });
      });

      window.addEventListener("beforeunload", () => {
        window.scrollTo(0, 0);
      });

      window.addEventListener("pageshow", (event) => {
        const navigation = performance.getEntriesByType("navigation")[0];
        const isReload = navigation?.type === "reload";

        if (event.persisted || isReload) {
          window.scrollTo(0, 0);
        }
      });
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <img class="brand-mark" src="/favicon.svg" alt="" width="24" height="24" />
          <span>Writing & Photos</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href="/">首页</a>
          <a href="/category/">分类</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>以图像保存光线，以文字整理时间。</p>
      </footer>
    </div>
  </body>
</html>
